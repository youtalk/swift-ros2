{
  "names": {
    "rmw_implementation": {
      "cmake-args": [
        "-DRMW_IMPLEMENTATION=rmw_cyclonedds_cpp",
        "-DRMW_IMPLEMENTATION_DISABLE_RUNTIME_SELECTION=ON"
      ]
    },
    "rcl": {
      "cmake-args": ["-DRCL_LOGGING_IMPLEMENTATION=rcl_logging_noop"]
    },
    "cyclonedds": {
      "cmake-args": ["-DENABLE_SHM=OFF", "-DENABLE_SECURITY=OFF", "-DENABLE_SSL=OFF", "-DENABLE_LTO=OFF"]
    }
  }
}
